      <tbody>
        <tr>
          <td rowspan="3"><strong>Performance API</strong></td>
          <td>Temps de réponse moyen (p50)</td>
          <td>&gt; 200 ms</td>
          <td>Dégradation UX perceptible</td>
        </tr>
        <tr>
          <td>Temps de réponse p95</td>
          <td>&gt; 500 ms</td>
          <td>Timeout possible sur mobile</td>
        </tr>
        <tr>
          <td>Taux d'erreurs HTTP 5xx</td>
          <td>&gt; 1 %</td>
          <td>Incident applicatif en cours</td>
        </tr>
        <tr>
          <td rowspan="2"><strong>Base de données</strong></td>
          <td>Temps de réponse requêtes DB</td>
          <td>&gt; 100 ms (p50)</td>
          <td>Requêtes non optimisées ou surcharge</td>
        </tr>
        <tr>
          <td>Connexions actives PostgreSQL</td>
          <td>&gt; 80 % du pool</td>
          <td>Risque de saturation du pool</td>
        </tr>
        <tr>
          <td rowspan="2"><strong>Infrastructure</strong></td>
          <td>Utilisation mémoire (RSS)</td>
          <td>&gt; 80 % de la limite Railway</td>
          <td>OOM Kill possible</td>
        </tr>
        <tr>
          <td>Taux de hit Redis (cache)</td>
          <td>&lt; 60 %</td>
          <td>Cache inefficace, surcharge DB</td>
        </tr>
        <tr>
          <td rowspan="3"><strong>Métriques métier</strong></td>
          <td>Réservations créées / heure</td>
          <td>Chute &gt; 50 % vs baseline</td>
          <td>Anomalie fonctionnelle possible</td>
        </tr>
        <tr>
          <td>Paiements Stripe échoués / total</td>
          <td>&gt; 5 %</td>
          <td>Problème d'intégration Stripe</td>
        </tr>
        <tr>
          <td>Tentatives de login échouées / min</td>
          <td>&gt; 20 / min par IP</td>
          <td>Attaque par force brute en cours</td>
        </tr>
      </tbody>
    </table>

    <h3>Commandes de vérification du monitoring</h3>
    <pre style="background:var(--color-bg,#0d1117);color:var(--color-text,#e6edf3);border:1px solid var(--color-border,#30363d);border-radius:6px;padding:1rem 1.25rem;font-size:0.82rem;line-height:1.6;overflow-x:auto;font-family:'Fira Mono','Cascadia Code',monospace;"># Vérifier que Prometheus collecte bien les métriques INKSPOT
curl https://prometheus-inkspot.up.railway.app/-/healthy
# → "Prometheus is Healthy."

# Vérifier l'endpoint de métriques de l'application
curl https://inkspot-app.up.railway.app/api/health
# → &#123;"status":"ok","db":"connected","redis":"connected"&#125;

# Lister les cibles Prometheus actives (toutes doivent être UP)
curl https://prometheus-inkspot.up.railway.app/api/v1/targets | jq '.data.activeTargets[] | &#123;job: .labels.job, health: .health&#125;'

# Vérifier les alertes actives dans Grafana
curl -u admin:votre-mot-de-passe-grafana https://grafana-inkspot.up.railway.app/api/alerts?state=alerting</pre>

    <h3>Bonnes pratiques de supervision</h3>
    <ul class="list-tight">
      <li><strong>Revue quotidienne</strong> : consulter le dashboard INKSPOT Overview chaque matin pour détecter les tendances anormales (latence, erreurs, activité métier).</li>
      <li><strong>Alertes Grafana</strong> : configurer des alertes email ou webhook (Slack) sur les métriques critiques (taux d'erreurs 5xx, temps de réponse p95, saturation mémoire).</li>
      <li><strong>Rétention des logs</strong> : Loki conserve les logs 7 jours par défaut — augmenter à 30 jours en production pour faciliter les investigations post-incident.</li>
      <li><strong>Revue mensuelle</strong> : analyser les tendances de performance sur 30 jours pour anticiper les besoins de scalabilité (augmentation des ressources Railway, optimisation des requêtes DB).</li>
      <li><strong>Tests de charge périodiques</strong> : exécuter un test de charge trimestriel pour valider que les seuils de performance restent dans les limites définies au cahier de recette (section 7.1).</li>
    </ul>
